OPENAI_API_KEY=
OPENAI_BASE_URL=
MODEL_NAME=
MODEL_EMPTY_RESPONSE_RETRIES=1

# 可选：填写后覆盖代码中的默认系统提示词；留空时使用内置模板。
SYSTEM_PROMPT=

# 每次模型调用最多携带多少条历史消息；System Prompt 不计入此限制。
MAX_HISTORY_MESSAGES=21

# 单次聊天请求允许模型发起的最大工具调用轮数。
MAX_TOOL_ROUNDS=3

# 本地知识库目录与检索参数。
KNOWLEDGE_DIR=knowledge
KNOWLEDGE_CHUNK_SIZE=800
KNOWLEDGE_CHUNK_OVERLAP=80
KNOWLEDGE_TOP_K=3
KNOWLEDGE_MAX_TOP_K=5
KNOWLEDGE_MAX_QUERY_CHARACTERS=500
